generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLIENT
}

enum DocumentType {
  ARRIVAL_NOTICE
  CREW_LIST
  SAILING_PERMIT
  MANIFEST
  K11
  OTHER
}

enum ReviewStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SlotType {
  NEW_SHIP
  PC
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String
  role               UserRole            @default(CLIENT)
  documents          DocumentSubmission[]
  applications       Application[]
  reviewedDocuments  DocumentSubmission[] @relation("DocumentReviewer")
  reviewedApplications Application[]      @relation("ApplicationReviewer")
  bulletins          Bulletin[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model DocumentSubmission {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewerId   String?
  reviewer     User?        @relation("DocumentReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  type         DocumentType
  originalName String
  filePath     String
  note         String?
  status       ReviewStatus @default(PENDING)
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([userId, status])
}

model Application {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewerId   String?
  reviewer     User?             @relation("ApplicationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  companyName  String
  vesselName   String
  vesselNo     String?
  slotType     SlotType
  arrivalDate  DateTime?
  remarks      String?
  pdfPath      String?
  status       ApplicationStatus @default(PENDING)
  adminNote    String?
  submittedAt  DateTime          @default(now())
  reviewedAt   DateTime?
  files        ApplicationFile[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, status])
}

model ApplicationFile {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type          DocumentType
  originalName  String
  filePath      String
  createdAt     DateTime    @default(now())
}

model Bulletin {
  id        String   @id @default(cuid())
  title     String
  body      String
  isActive  Boolean  @default(true)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}